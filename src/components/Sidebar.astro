---
// Fixed-position sidebar: avatar, name, role, email, social icons.
---
<aside class="ll-sidebar">
  <div class="ll-sidebar__branch" aria-hidden="true"></div>
  <div class="ll-sidebar__inner ll-sidebar__inner--right">

    <img class="ll-sidebar__avatar" src="/headshot.jpg" alt="Yemko Pryor" />

    <h1 class="ll-sidebar__name">Yemko Pryor</h1>
    <p class="ll-sidebar__role">
      Postdoctoral Researcher<br />
      University of Michigan<br />
      <a href="https://lsa.umich.edu/anthro" target="_blank" rel="noopener">Department of Anthropology</a><br />
      <a href="https://www.lasisilab.com/" target="_blank" rel="noopener">Lasisi Lab</a>
    </p>

    <section class="tl-sb-affil" aria-label="Email">
      <p class="tl-sb-heading">Email</p>
      <p class="tl-sb-email">ypryor [at] umich [dot] edu</p>
    </section>

    <nav class="tl-sb-icons" aria-label="Profiles & social">
      <!-- TODO: Replace YOUR_SCHOLAR_ID with your actual Google Scholar user ID -->
      <a href="https://scholar.google.com/citations?user=YOUR_SCHOLAR_ID" target="_blank" rel="noopener" aria-label="Google Scholar"><i class="ai ai-google-scholar" aria-hidden="true"></i></a>
      <!-- TODO: Replace YOUR_ORCID with your ORCID (format: 0000-0000-0000-0000) -->
      <a href="https://orcid.org/YOUR_ORCID" target="_blank" rel="noopener" aria-label="ORCID"><i class="ai ai-orcid" aria-hidden="true"></i></a>
      <a href="https://github.com/ypryor" target="_blank" rel="noopener" aria-label="GitHub"><i class="fa-brands fa-github" aria-hidden="true"></i></a>
      <!-- TODO: Replace YOUR_LINKEDIN_HANDLE with your LinkedIn username -->
      <a href="https://www.linkedin.com/in/YOUR_LINKEDIN_HANDLE/" target="_blank" rel="noopener" aria-label="LinkedIn"><i class="fa-brands fa-linkedin-in" aria-hidden="true"></i></a>
    </nav>

  </div>
</aside>
