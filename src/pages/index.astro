---
import Base from '../layouts/Base.astro';
import Sidebar from '../components/Sidebar.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { affiliations } from '../data/affiliations';
import { upcoming, recent } from '../data/events';
---
<Base title="Yemko Pryor">
  <div class="ll-layout" data-screen-label="Home">
    <Sidebar />

    <div class="ll-content">
      <SiteHeader />

      <main class="tl-main">

        <section class="tl-about">
          <p class="eyebrow">About</p>
          <p class="tl-about__body">
            I'm a biological anthropologist and postdoctoral researcher in the
            <a href="https://www.lasisilab.com/" target="_blank" rel="noopener">Lasisi Lab</a>
            at the University of Michigan. My research examines how evolutionary
            forces have shaped human genomic diversity, with a focus on
            populations of African descent. I combine ancient DNA, historical
            genomics, and population genetic methods to understand patterns of
            natural selection and the interplay between genetic and epigenetic
            variation across generations.
          </p>

          {affiliations.length > 0 && (
            <section class="tl-affil" id="affiliations" aria-label="Affiliations">
              <p class="eyebrow tl-events__subhead">Affiliations</p>
              <ul class="tl-affil__list">
                {affiliations.map((a) => (
                  <li>
                    <a href={a.href} target="_blank" rel="noopener">{a.name}</a>
                    <span class="tl-affil__sub">{a.sub}</span>
                  </li>
                ))}
              </ul>
            </section>
          )}

          <div class="tl-cta-row">
            <!-- TODO: Replace the href below with a link to your CV (e.g. a Google Drive share link) -->
            <a class="ll-btn ll-btn--primary" href="#" target="_blank" rel="noopener">
              Download CV
            </a>
            <a class="ll-btn tl-btn-ghost" href="https://www.lasisilab.com" target="_blank" rel="noopener">
              Visit lab website →
            </a>
          </div>
        </section>

        <section class="tl-events" id="events" aria-label="Events">
          <p class="eyebrow">Events</p>

          <p class="eyebrow tl-events__subhead">Upcoming</p>
          {upcoming.length > 0 ? (
            <ul class="ll-postlist">
              {upcoming.map((e) => (
                <li class="ll-postlist__item">
                  <a class="ll-postlist__link" href={e.href} target="_blank" rel="noopener">
                    <div class="ll-postlist__meta">
                      <span class={`ll-tag ll-tag--${e.tagColor}`}>{e.tag}</span>
                      <span class="ll-postlist__date" set:html={e.date}></span>
                    </div>
                    <h3 class="ll-postlist__title" set:html={e.title}></h3>
                    <p class="ll-postlist__summary">{e.summary}</p>
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="tl-about__body" style="color: var(--fg-muted);">Nothing scheduled yet — check back soon.</p>
          )}

          {recent.length > 0 && (
            <>
              <p class="eyebrow eyebrow--muted tl-events__subhead">Recent</p>
              <ul class="ll-postlist ll-postlist--past">
                {recent.map((e) => (
                  <li class="ll-postlist__item ll-postlist__item--past">
                    <a class="ll-postlist__link" href={e.href} target="_blank" rel="noopener">
                      <div class="ll-postlist__meta">
                        <span class={`ll-tag ll-tag--${e.tagColor}`}>{e.tag}</span>
                        <span class="ll-postlist__date" set:html={e.date}></span>
                      </div>
                      <h3 class="ll-postlist__title" set:html={e.title}></h3>
                      <p class="ll-postlist__summary">{e.summary}</p>
                    </a>
                  </li>
                ))}
              </ul>
            </>
          )}
        </section>

        <section class="tl-contact" id="contact" aria-label="Contact">
          <p class="eyebrow">Get in touch</p>
          <h2 class="tl-contact__title">Contact</h2>
          <p class="tl-contact__lead">Feel free to reach out — I'm always happy to connect.</p>

          <!-- TODO: Replace href with your own contact form URL, or remove this button and just list your email -->
          <a class="ll-btn ll-btn--accent" href="mailto:ypryor@umich.edu">
            Send me an email →
          </a>
        </section>

      </main>

      <footer class="ll-footer">
        <img src="/mark-teal.png" alt="" class="tl-footer__mark" />
        <p class="tl-footer__copy">© 2026 Yemko Pryor</p>
      </footer>
    </div>
  </div>
</Base>
